# Production Environment Variables Example
# Copy this file to .env.production and fill in the values
# DO NOT commit .env.production to version control

# ============================================
# Required Variables
# ============================================

# NextAuth Secrets (generate with: openssl rand -base64 32)
AUTH_SECRET=your-production-secret-key-here-replace-me
NEXTAUTH_SECRET=your-production-secret-key-here-replace-me

# Initial Admin Credentials
INITIAL_ADMIN_PASSWORD=your-secure-password-here

# Application URL (change to your production domain)
NEXTAUTH_URL=https://your-domain.com

# ============================================
# Database Configuration
# ============================================

POSTGRES_DB=conference-child-mgmt
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure-database-password-here

# ============================================
# Optional Configuration
# ============================================

# Port mappings (defaults shown)
DB_PORT=5432
APP_PORT=3000

# Initial admin username
INITIAL_ADMIN_USERNAME=admin

# ============================================
# Usage
# ============================================

# 1. Copy this file:
#    cp .env.production.example .env.production

# 2. Generate secrets:
#    openssl rand -base64 32

# 3. Load and start:
#    set -a; source .env.production; set +a
#    docker-compose -f docker-compose.prod.yml up --build -d
