# Production Environment Configuration
# Copy this file to .env.prod and update with your actual values

# Django Settings
SECRET_KEY=change-this-to-a-random-secret-key-in-production
DJANGO_SETTINGS_MODULE=config.settings.prod
DEBUG=false

# Allowed hosts (comma-separated, no spaces)
# IMPORTANT: Only include hostnames/IPs, NOT ports
# Django automatically handles ports - ALLOWED_HOSTS validates the Host header
#
# Examples:
# - Domain: yourdomain.com,www.yourdomain.com
# - IP address: 192.168.1.164,localhost
# - Both: yourdomain.com,192.168.1.164,localhost
#
# DO NOT include ports like "192.168.1.164:8080" - Django strips ports automatically
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost

# Database
DATABASE_URL=postgresql://postgres:secure_password@db:5432/checkins

# Redis/Valkey
VALKEY_URL=redis://valkey:6379/0

# CORS and CSRF (comma-separated, no spaces)
# Use the public-facing URLs that browsers will use
# If behind reverse proxy, use the proxy's URL (e.g., https://yourdomain.com)
# If direct access on port 8080, use http://yourdomain.com:8080
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# SSL/Security
# IMPORTANT: Set these based on your deployment scenario
# For HTTPS (reverse proxy with SSL): SESSION_COOKIE_SECURE=true, CSRF_COOKIE_SECURE=true
# For HTTP (local testing without SSL): SESSION_COOKIE_SECURE=false, CSRF_COOKIE_SECURE=false
# Default in docker-compose.prod.yml is 'false' for easy local testing
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false

# ===== Reverse Proxy Configuration =====
# If running behind Nginx/Caddy/etc with SSL:
# - Set SESSION_COOKIE_SECURE=true and CSRF_COOKIE_SECURE=true
# - Use https:// URLs in CORS_ALLOWED_ORIGINS and CSRF_TRUSTED_ORIGINS
# - Configure reverse proxy to forward headers (X-Forwarded-Proto, etc.)
# - Django container runs on port 8000 internally, exposed as 8080 on host
# - Point reverse proxy to localhost:8080
#
# If accessing directly on port 8080 without reverse proxy (e.g., local testing):
# - ALLOWED_HOSTS: Add your IP/hostname WITHOUT port (e.g., 192.168.1.164,localhost)
# - SESSION_COOKIE_SECURE=false and CSRF_COOKIE_SECURE=false
# - CORS_ALLOWED_ORIGINS: Include port (e.g., http://192.168.1.164:8080,http://localhost:8080)
# - CSRF_TRUSTED_ORIGINS: Include port (e.g., http://192.168.1.164:8080,http://localhost:8080)
#
# Example for local network access:
# ALLOWED_HOSTS=192.168.1.164,localhost
# CORS_ALLOWED_ORIGINS=http://192.168.1.164:8080,http://localhost:8080
# CSRF_TRUSTED_ORIGINS=http://192.168.1.164:8080,http://localhost:8080
