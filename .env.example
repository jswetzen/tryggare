# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Prisma
# PostgreSQL database connection string
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/conference-child-mgmt"

# NextAuth.js Configuration
# Application URL - set to your deployment URL in production
NEXTAUTH_URL="http://localhost:3000"

# NextAuth.js session secret - generate a secure random string
# Generate with: openssl rand -base64 32
# Note: NextAuth v5 uses AUTH_SECRET, but we support both for compatibility
AUTH_SECRET="your-secret-key-here-replace-with-random-string"
NEXTAUTH_SECRET="your-secret-key-here-replace-with-random-string"

# Initial Admin User
# These credentials are used to create the first admin user during database seeding
# Change these before running the seed script in production!
INITIAL_ADMIN_USERNAME="admin"
INITIAL_ADMIN_PASSWORD="changeme123"

# Feature Flags
# Control which features are enabled/disabled in the application

# Printer Integration (MVP: false - display QR codes on screen instead)
NEXT_PUBLIC_FEATURE_PRINTER_ENABLED="false"

# Full Admin CRUD (MVP: true - allow creating/managing admins in UI)
NEXT_PUBLIC_FEATURE_ADMIN_FULL_CRUD="true"

# QR Code Generation (MVP: true - generate QR codes for children)
NEXT_PUBLIC_FEATURE_QR_CODE_ENABLED="true"

# Audit Log UI (MVP: true - show audit logs in admin interface)
NEXT_PUBLIC_FEATURE_AUDIT_LOG_UI="true"
