# Production Environment Configuration - SECURE TEMPLATE
# Copy this file to .env.prod and update with your actual secure values
# IMPORTANT: Never commit .env.prod to git!

# Django Settings
# CRITICAL: Generate with: openssl rand -base64 50
# This is a placeholder - MUST be replaced with unique random value
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET_KEY_MINIMUM_50_CHARS
DJANGO_SETTINGS_MODULE=config.settings.prod
DEBUG=false

# Allowed hosts (comma-separated, no spaces)
# Include your domain AND any reverse proxy addresses
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost,127.0.0.1

# Database Configuration
# CRITICAL: Generate password with: openssl rand -base64 32
DB_USER=checkins_admin
DB_PASSWORD=REPLACE_WITH_GENERATED_DATABASE_PASSWORD_32_CHARS
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@db-prod:5432/checkins

# Redis/Valkey Configuration
# CRITICAL: Generate password with: openssl rand -base64 32
REDIS_PASSWORD=REPLACE_WITH_GENERATED_REDIS_PASSWORD_32_CHARS
VALKEY_URL=redis://:${REDIS_PASSWORD}@valkey-prod:6379/0

# CORS and CSRF (comma-separated, no spaces)
# For HTTPS production deployment, use https:// URLs
# For HTTP testing, use http:// URLs
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# SSL/Security Settings
# For HTTPS deployment (with reverse proxy): set to true
# For HTTP testing only: set to false
# IMPORTANT: Always use true for production with real data!
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_SSL_REDIRECT=true

# Admin Panel Security
# Change this to a non-standard path for production
ADMIN_URL_PATH=admin/

# ===== HTTPS/Reverse Proxy Setup =====
# If running behind Nginx/Caddy/Traefik with SSL:
# 1. Set all *_SECURE variables above to true
# 2. Use https:// URLs in CORS_ALLOWED_ORIGINS and CSRF_TRUSTED_ORIGINS
# 3. Configure reverse proxy to forward to http://localhost:8080
# 4. Reverse proxy handles SSL termination
#
# If accessing directly on port 8080 without reverse proxy (NOT RECOMMENDED FOR PRODUCTION):
# 1. Set all *_SECURE variables to false
# 2. Use http://yourdomain.com:8080 in CORS/CSRF settings
# 3. Access at http://yourdomain.com:8080
