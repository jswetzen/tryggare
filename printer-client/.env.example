# Backend URL (where the Django server is running)
BACKEND_URL=http://192.168.1.100:8080

# Staff credentials (used for WS authentication)
STAFF_USERNAME=admin
STAFF_PASSWORD=changeme

# Printer identity — generate a UUID once and keep it
PRINTER_UUID=00000000-0000-0000-0000-000000000001
PRINTER_NAME=Label Printer 1

# brother_ql printer settings
# PRINTER_IDENTIFIER: USB device (usb://0x04f9:0x2042) or network (tcp://192.168.1.50)
PRINTER_IDENTIFIER=usb://0x04f9:0x2042
PRINTER_BACKEND=pyusb   # pyusb | network | linux_kernel
PRINTER_MODEL=QL-700    # QL-700, QL-800, QL-1100, etc.
LABEL_SIZE=62           # Label width in mm (29, 38, 50, 54, 62, 102)

# Screenshot DPI for Playwright rendering (higher = better quality)
SCREENSHOT_DPI=300

# Set DRY_RUN=true to skip actual printing (useful for testing WS connectivity)
DRY_RUN=false
