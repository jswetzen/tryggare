# Backend URL — REQUIRED. Point this at your Django server.
BACKEND_URL=http://192.168.1.100:8080

# Per-printer auth token. Leave this blank on first run: the client prompts you
# to log in, provisions its own printer + token, and writes the token here. You
# can also set it manually (provision in the admin / API and paste it).
PRINTER_TOKEN=

# Optional: pre-seed staff credentials to skip the interactive login prompt
# (useful for scripted/headless setup with --non-interactive). They are used
# once to provision the token and then removed from this file automatically.
# STAFF_USERNAME=admin
# STAFF_PASSWORD=changeme

# Display name reported to the backend on connect (also the provisioned name).
PRINTER_NAME=Label Printer 1

# brother_ql printer settings
# PRINTER_IDENTIFIER: leave BLANK for a USB printer — a single connected Brother
# QL is auto-detected. Only set it to pin a specific device (usb://0x04f9:0x2042)
# or for the network backend (tcp://192.168.1.50, which is then REQUIRED).
PRINTER_IDENTIFIER=
PRINTER_BACKEND=pyusb   # pyusb | network | linux_kernel
PRINTER_MODEL=QL-700    # match your printer: QL-700, QL-800, QL-810W, QL-1100, etc.
# brother_ql label identifier — must match the media physically loaded.
# Die-cut: 29x90, 62x100, 29x42, 17x54   Endless tape: 29, 62
LABEL_SIZE=29x90

# Screenshot DPI for Playwright rendering (higher = better quality)
SCREENSHOT_DPI=300

# Set DRY_RUN=true to skip actual printing (useful for testing WS connectivity)
DRY_RUN=false
