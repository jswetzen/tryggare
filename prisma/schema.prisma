// Conference Child Management System - Prisma Schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
    provider      = "prisma-client-js"
    output        = "../generated/prisma"
    binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ============================================================================
// Admin & Authentication Models
// ============================================================================

model AdminUser {
    id        String    @id @default(cuid())
    username  String    @unique
    passwordHash String
    name      String
    createdAt DateTime  @default(now())
    lastLogin DateTime?
    isActive  Boolean   @default(true)

    // Relations
    checkInsPerformed  CheckInRecord[] @relation("CheckInStaff")
    checkOutsPerformed CheckInRecord[] @relation("CheckOutStaff")

    @@map("admin_users")
}

// ============================================================================
// Family & Contact Models
// ============================================================================

model Family {
    id                     String    @id @default(cuid())
    lastParticipationDate  DateTime?

    // Relations
    parents  Parent[]
    children Child[]

    @@map("families")
}

model Parent {
    id                     String    @id @default(cuid())
    name                   String
    phone                  String?
    email                  String?
    relationshipType       String    // "Mom", "Dad", or free text
    lastParticipationDate  DateTime?
    familyId               String

    // Relations
    family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

    @@index([familyId])
    @@map("parents")
}

// ============================================================================
// Child Model
// ============================================================================

model Child {
    id                     String    @id @default(cuid())
    firstName              String
    lastName               String
    birthdate              DateTime
    allergies              String?
    notes                  String?
    qrToken                String?   @unique // UUID, generated on first check-in
    lastParticipationDate  DateTime?
    familyId               String

    // Relations
    family         Family          @relation(fields: [familyId], references: [id], onDelete: Cascade)
    checkInRecords CheckInRecord[]
    tickets        Ticket[]

    @@index([qrToken])
    @@index([lastName])
    @@index([familyId])
    @@map("children")
}

// ============================================================================
// Event & Session Models
// ============================================================================

model Event {
    id        String   @id @default(cuid())
    name      String
    startDate DateTime
    endDate   DateTime

    // Relations
    sessions Session[]
    tickets  Ticket[]

    @@map("events")
}

model Session {
    id             String   @id @default(cuid())
    name           String
    startTime      DateTime
    endTime        DateTime
    isActive       Boolean  @default(false)
    requiresTicket Boolean  @default(false)
    eventId        String

    // Relations
    event          Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
    checkInRecords CheckInRecord[]
    tickets        Ticket[]

    @@index([eventId])
    @@index([isActive])
    @@map("sessions")
}

// ============================================================================
// Ticket & Check-In Models
// ============================================================================

model Ticket {
    id        String  @id @default(cuid())
    type      String  // "EVENT_PASS", "SESSION_TICKET", "NONE"
    childId   String
    sessionId String?
    eventId   String?

    // Relations
    child   Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
    session Session? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
    event   Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)

    @@index([childId])
    @@index([sessionId])
    @@index([eventId])
    // Prisma 6.19 does not yet support @@check, but the migration adds the
    // "tickets_require_event_or_session" database constraint to enforce that
    // exactly one of event_id or session_id is populated.
    @@map("tickets")
}

model CheckInRecord {
    id             String    @id @default(cuid())
    checkInTime    DateTime  @default(now())
    checkOutTime   DateTime?
    pickedUpBy     String?
    childId        String
    sessionId      String
    checkInStaffId String
    checkOutStaffId String?

    // Relations
    child          Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
    session        Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
    checkInStaff   AdminUser @relation("CheckInStaff", fields: [checkInStaffId], references: [id])
    checkOutStaff  AdminUser? @relation("CheckOutStaff", fields: [checkOutStaffId], references: [id])

    @@unique([childId, sessionId, checkInTime])
    @@index([childId])
    @@index([sessionId])
    @@index([checkInStaffId])
    @@index([checkOutStaffId])
    @@map("check_in_records")
}

// ============================================================================
// Audit Log Model
// ============================================================================

model AuditLog {
    id         String   @id @default(cuid())
    timestamp  DateTime @default(now())
    userId     String   // AdminUser ID
    action     String   // "CHECK_IN", "CHECK_OUT", "CREATE_FAMILY", etc.
    entityType String   // "Child", "Family", "Session", etc.
    entityId   String
    details    Json?    // Additional context

    @@index([timestamp])
    @@index([userId])
    @@index([entityType])
    @@map("audit_logs")
}
